PORT=8080
DB_DRIVER=postgres
DATABASE_URL=postgresql://postgres:pass@172.20.0.16:5432/auditer?sslmode=disable

# Redis (for rate limiting and circuit breaker)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
# Alternative: REDIS_URL=redis://localhost:6379

# Gateway upstream provider keys (OpenRouter-style proxy mode)
GATEWAY_DEFAULT_UPSTREAM_API_KEY=
GATEWAY_OPENAI_API_KEY=
GATEWAY_ANTHROPIC_API_KEY=
GATEWAY_GOOGLE_API_KEY=
GATEWAY_AZURE_API_KEY=
GATEWAY_OLLAMA_API_KEY=
GATEWAY_MINIMAX_API_KEY=
GATEWAY_ZHIPUAI_API_KEY=
GATEWAY_DEEPSEEK_API_KEY=
GATEWAY_BAIDU_API_KEY=
GATEWAY_ALIBABA_API_KEY=

# Embedding service (for evaluator)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
